rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — lecture publique, écriture uniquement par le propriétaire
    match /users/{uid} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['pseudo', 'favoriteRemedyIds', 'createdRemediesCount']);
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Remèdes — lecture publique, création authentifiée, modification par l'auteur
    match /remedies/{remedyId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 200;
      allow update: if request.auth != null
        && (resource.data.authorId == request.auth.uid
            || request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['averageRating', 'ratingCount', 'commentCount']));
      allow delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;

      // Commentaires
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() <= 1000;
        allow delete: if request.auth != null
          && resource.data.authorId == request.auth.uid;
        allow update: if false;
      }

      // Notes (une par utilisateur)
      match /ratings/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId
          && request.resource.data.stars is int
          && request.resource.data.stars >= 1
          && request.resource.data.stars <= 5;
      }
    }

    // Signalements — écriture authentifiée uniquement, lecture admin uniquement
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}
